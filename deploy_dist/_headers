/*
  Content-Security-Policy: default-src 'self' 'unsafe-eval' 'unsafe-inline' https: data: blob: ws: wss:; script-src 'self' 'unsafe-eval' 'unsafe-inline' https: blob:; worker-src 'self' blob:; connect-src 'self' https: wss: ws: http://localhost:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:;
